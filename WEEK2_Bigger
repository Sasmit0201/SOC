import torch
import torch.nn as nn
import torch.nn.functional as F
import torch.optim as optim
import matplotlib.pyplot as plt
import numpy as np
import random
from dataclasses import dataclass

# We set up a strict configuration object to manage the complexity
@dataclass
class NCAConfig:
    grid_size: int = 40
    channels: int = 16
    hidden_dim: int = 128
    fire_rate: float = 0.5
    batch_size: int = 8
    pool_size: int = 256
    epochs: int = 800
    lr: float = 2e-3

config = NCAConfig()
device = torch.device("cuda" if torch.cuda.is_available() else "cpu")

# 1. CORE ARCHITECTURE

class Perception(nn.Module):
    """
    Extracts spatial gradients. We keep the filters fixed because forcing the network 
    to relearn basic 2D geometry from scratch is a waste of parameters.
    """
    def __init__(self, channels):
        super().__init__()
        self.channels = channels
        
        ident = torch.tensor([[0., 0., 0.], [0., 1., 0.], [0., 0., 0.]])
        sobel_x = torch.tensor([[-1., 0., 1.], [-2., 0., 2.], [-1., 0., 1.]])
        sobel_y = torch.tensor([[-1., -2., -1.], [0., 0., 0.], [1., 2., 1.]])
        laplacian = torch.tensor([[1., 2., 1.], [2., -12., 2.], [1., 2., 1.]])
        
        filters = torch.stack([ident, sobel_x, sobel_y, laplacian])
        filters = filters.repeat(channels, 1, 1).unsqueeze(1)
        self.register_buffer('filters', filters)

    def forward(self, x):
        return F.conv2d(x, self.filters, padding=1, groups=self.channels)

class ResBlock(nn.Module):
    """
    A standard residual block using 1x1 convolutions. 
    Crucial for allowing deep cell logic without gradient degradation.
    """
    def __init__(self, dim):
        super().__init__()
        self.conv1 = nn.Conv2d(dim, dim, 1)
        self.conv2 = nn.Conv2d(dim, dim, 1)

    def forward(self, x):
        residual = x
        out = F.relu(self.conv1(x))
        out = self.conv2(out)
        return out + residual

class UpdateNetwork(nn.Module):
    """
    The cell's brain. Projects the 64 perceived inputs into a high-dimensional space,
    processes them through residual blocks, and projects back to a 16-channel update.
    """
    def __init__(self, in_dim, hidden_dim, out_dim):
        super().__init__()
        self.encoder = nn.Conv2d(in_dim, hidden_dim, 1)
        
        self.res_blocks = nn.Sequential(
            ResBlock(hidden_dim),
            nn.ReLU(),
            ResBlock(hidden_dim),
            nn.ReLU()
        )
        
        self.decoder = nn.Conv2d(hidden_dim, out_dim, 1)
        
        with torch.no_grad():
            self.decoder.weight.zero_()
            self.decoder.bias.zero_()

    def forward(self, x):
        x = F.relu(self.encoder(x))
        x = self.res_blocks(x)
        return self.decoder(x)

class ComplexNCA(nn.Module):
    """
    The orchestrator. Handles perception, updates, stochastic masking, and the physical 
    constraints of the grid (alpha thresholding).
    """
    def __init__(self, cfg: NCAConfig):
        super().__init__()
        self.cfg = cfg
        self.perceive = Perception(cfg.channels)
        self.update_net = UpdateNetwork(cfg.channels * 4, cfg.hidden_dim, cfg.channels)

    def forward(self, x):
        perception_grid = self.perceive(x)
        update = self.update_net(perception_grid)
        
        # Asynchronous firing simulation
        stochastic_mask = (torch.rand(x[:, 0:1, :, :].shape, device=x.device) <= self.cfg.fire_rate).float()
        x = x + update * stochastic_mask
        
        # Dead cells stay dead. Living cells need support to survive.
        alive_mask = F.max_pool2d(x[:, 3:4, :, :], kernel_size=3, stride=1, padding=1) > 0.1
        return x * alive_mask.float()


# 2. TRAINING INFRASTRUCTURE

class SamplePool:
    """
    Stores a history of grid states. By periodically pulling mature organisms from this pool 
    and continuing to train them, we prevent the model from forgetting how to maintain stability.
    """
    def __init__(self, pool_size, cfg: NCAConfig):
        self.pool = torch.zeros(pool_size, cfg.channels, cfg.grid_size, cfg.grid_size).to(device)
        # Initialize every slot in the pool with a valid central seed
        self.pool[:, 3:, cfg.grid_size//2, cfg.grid_size//2] = 1.0

    def sample(self, batch_size):
        indices = random.sample(range(len(self.pool)), batch_size)
        return self.pool[indices].clone(), indices

    def commit(self, batch, indices):
        self.pool[indices] = batch.detach()

def create_complex_target(size):
    """Generates a geometric target with distinct color quadrants to test feature learning."""
    target = torch.zeros(4, size, size).to(device)
    center = size // 2
    offset = 4
    
    # Draw four distinct colored blocks that form a hollow center
    target[3, offset:center-2, offset:center-2] = 1.0  # Top-Left Alpha
    target[0, offset:center-2, offset:center-2] = 1.0  # Top-Left Red
    
    target[3, center+2:-offset, offset:center-2] = 1.0 # Bottom-Left Alpha
    target[1, center+2:-offset, offset:center-2] = 1.0 # Bottom-Left Green
    
    target[3, offset:center-2, center+2:-offset] = 1.0 # Top-Right Alpha
    target[2, offset:center-2, center+2:-offset] = 1.0 # Top-Right Blue
    
    target[3, center+2:-offset, center+2:-offset] = 1.0 # Bottom-Right Alpha
    target[0, center+2:-offset, center+2:-offset] = 0.8 # Bottom-Right Magenta
    target[2, center+2:-offset, center+2:-offset] = 0.8 
    return target

class NCATrainer:
    """Encapsulates the entire training pipeline, managing optimizers, schedulers, and the state pool."""
    def __init__(self, model, cfg: NCAConfig):
        self.model = model
        self.cfg = cfg
        self.target = create_complex_target(cfg.grid_size)
        self.pool = SamplePool(cfg.pool_size, cfg)
        
        self.optimizer = optim.Adam(model.parameters(), lr=cfg.lr)
        # Cosine Annealing smoothly drops the learning rate, helping the network settle into a stable minima
        self.scheduler = optim.lr_scheduler.CosineAnnealingLR(self.optimizer, T_max=cfg.epochs)
        self.loss_fn = nn.MSELoss()

    def train(self):
        print(f"Beginning deep training on {device}...")
        for epoch in range(self.cfg.epochs + 1):
            
            # Pull a batch of grids from our historical pool
            x, indices = self.pool.sample(self.cfg.batch_size)
            
            # Always replace the first item in the batch with a brand new seed.
            # This ensures the model never forgets how to start from scratch.
            x[0] *= 0.0
            x[0, 3:, self.cfg.grid_size//2, self.cfg.grid_size//2] = 1.0
            
            # Apply random permutations to force rotation/translation invariance if needed
            # (Skipped here for target alignment strictly, but useful for advanced CAs)

            growth_steps = np.random.randint(64, 96)
            for _ in range(growth_steps):
                x = self.model(x)

            # Calculate loss against the expanded target batch
            target_batch = self.target.unsqueeze(0).repeat(self.cfg.batch_size, 1, 1, 1)
            loss = self.loss_fn(x[:, :4, :, :], target_batch)

            self.optimizer.zero_grad()
            loss.backward()
            
            # Strict gradient normalization. The recursive nature of NCAs will cause 
            # floating point overflow (NaNs) without this.
            with torch.no_grad():
                for p in self.model.parameters():
                    if p.grad is not None:
                        p.grad /= (p.grad.norm() + 1e-8)
                        
            self.optimizer.step()
            self.scheduler.step()
            
            # Save the states back to the pool so they can continue growing later
            self.pool.commit(x, indices)

            if epoch % 100 == 0:
                lr = self.scheduler.get_last_lr()[0]
                print(f"Epoch {epoch:04d} | Loss: {loss.item():.6f} | LR: {lr:.5f}")


# 3. EVALUATION & VISUALIZATION

class ExperimentEvaluator:
    """Dedicated class to handle the execution of Coursework Tasks 3 and 4."""
    def __init__(self, model, cfg: NCAConfig):
        self.model = model
        self.cfg = cfg

    def _to_rgb(self, tensor):
        rgb = tensor[0, :3].permute(1, 2, 0).cpu().detach().numpy()
        alpha = tensor[0, 3:4].permute(1, 2, 0).cpu().detach().numpy()
        return np.clip(rgb * alpha, 0, 1)

    def execute_task3_growth(self):
        print("\nExecuting Task 3: Spontaneous Morphogenesis")
        grid = torch.zeros(1, self.cfg.channels, self.cfg.grid_size, self.cfg.grid_size).to(device)
        grid[0, 3:, self.cfg.grid_size//2, self.cfg.grid_size//2] = 1.0 
        
        states = [("Seed (0)", self._to_rgb(grid))]
        
        with torch.no_grad():
            for step in range(1, 101):
                grid = self.model(grid)
                if step == 30:
                    states.append(("Adolescent (30)", self._to_rgb(grid)))
                elif step == 100:
                    states.append(("Mature (100)", self._to_rgb(grid)))

        fig, axes = plt.subplots(1, 3, figsize=(12, 4))
        for ax, (title, img) in zip(axes, states):
            ax.imshow(img)
            ax.set_title(title)
            ax.axis('off')
        plt.suptitle("Task 3: Deep NCA Growth Sequence")
        plt.show()
        return grid

    def execute_task4_ablation(self, mature_grid):
        print("\nExecuting Task 4: Ablation and Regeneration")
        pre_damage = self._to_rgb(mature_grid)
        
        # Simulate a macroscopic physical trauma (slice through the center)
        grid = mature_grid.clone()
        grid[:, :, 15:25, :] = 0.0
        damaged = self._to_rgb(grid)
        
        with torch.no_grad():
            for _ in range(120): # Give it slightly more time to heal a massive wound
                grid = self.model(grid)
                
        recovered = self._to_rgb(grid)
        
        fig, axes = plt.subplots(1, 3, figsize=(12, 4))
        axes[0].imshow(pre_damage); axes[0].set_title("Pre-Trauma State")
        axes[1].imshow(damaged); axes[1].set_title("Equatorial Ablation Imposed")
        axes[2].imshow(recovered); axes[2].set_title("Autonomous Recovery (+120)")
        for ax in axes: ax.axis('off')
        plt.suptitle("Task 4: Structural Regeneration")
        plt.show()


# EXECUTION BLOCK

if __name__ == "__main__":
    nca_model = ComplexNCA(config).to(device)
    
    # Train the complex network
    trainer = NCATrainer(nca_model, config)
    trainer.train()
    
    # Run the visualization tasks
    evaluator = ExperimentEvaluator(nca_model, config)
    grown_organism = evaluator.execute_task3_growth()
    evaluator.execute_task4_ablation(grown_organism)
